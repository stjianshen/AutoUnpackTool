<Window x:Class="AutoUnpackTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AutoUnpackTool"
        Title="自动觧压工具 V1.0" Height="650" Width="1100"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Closing="Window_Closing">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 第一行：目录选择和模式选择 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <Button x:Name="BtnSelectDirectory" Content="选择目录" Width="100" Height="30" Click="BtnSelectDirectory_Click" Margin="0,0,10,0"/>
            <TextBox x:Name="TxtOutputDirectory" Width="450" Height="30" IsReadOnly="True" VerticalContentAlignment="Center"/>
            
            <!-- 解压模式选择 -->
            <RadioButton x:Name="RdoManualMode" Content="手动解压" GroupName="ExtractMode" VerticalAlignment="Center" Margin="15,0,0,0" IsChecked="True"/>
            <RadioButton x:Name="RdoAutoMode" Content="自动解压" GroupName="ExtractMode" VerticalAlignment="Center" Margin="10,0,0,0"/>
            
            <!-- 状态显示（顶部右侧） -->
            <TextBlock x:Name="TxtStatusMain" Text="状态: 未开始" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold" Foreground="Gray"/>
        </StackPanel>

        <!-- 第二行：主要操作按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <!-- 统一操作按钮（根据状态自动切换功能） -->
            <Button x:Name="BtnMainAction" Content="开始解压" Width="100" Height="30" Click="BtnMainAction_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnClear" Content="清空内容" Width="100" Height="30" Click="BtnClear_Click" Margin="0,0,10,0"/>
            
            <Separator Width="20" Visibility="Hidden"/>
            
            <Button x:Name="BtnPasswordConfig" Content="编辑密码" Width="100" Height="30" Click="BtnPasswordConfig_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnSettings" Content="软件设置" Width="100" Height="30" Click="BtnSettings_Click"/>
        </StackPanel>

        <!-- 第三行：控制选项 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="重复文件:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="CmbDuplicateAction" Width="120" Height="30" SelectedIndex="0">
                <ComboBoxItem Content="跳过"/>
                <ComboBoxItem Content="覆盖"/>
                <ComboBoxItem Content="重命名"/>
            </ComboBox>

            <Separator Width="20" Visibility="Hidden"/>
            
            <!-- 强制解压模式复选框 -->
            <CheckBox x:Name="ChkForceExtractMode" Content="强制解压模式(跳过检测)" VerticalAlignment="Center" Margin="10,0,0,0" Checked="ChkForceExtractMode_Changed" Unchecked="ChkForceExtractMode_Changed"/>
            
            <Separator Width="20" Visibility="Hidden"/>
            
            <!-- 最大解压层数设置（下拉列表） -->
            <TextBlock Text="最大解压层数:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <ComboBox x:Name="CmbMaxExtractDepth" Width="100" Height="30" VerticalContentAlignment="Center"
                      IsEditable="True" SelectionChanged="CmbMaxExtractDepth_SelectionChanged"
                      LostFocus="CmbMaxExtractDepth_LostFocus" Text="0">
                <ComboBoxItem Content="不限制"/>
                <ComboBoxItem Content="1 层"/>
                <ComboBoxItem Content="2 层"/>
                <ComboBoxItem Content="3 层"/>
                <ComboBoxItem Content="5 层"/>
                <ComboBoxItem Content="10 层"/>
            </ComboBox>
        </StackPanel>

        <!-- 主内容区域 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：拖放的文件列表 -->
            <GroupBox Grid.Column="0" Header="拖拽的文件" Margin="0,0,0,0">
                <TreeView x:Name="LstFiles" 
                          Background="White"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          SelectedItemChanged="TreeView_SelectedItemChanged">
                    <TreeView.Resources>
                        <!-- RootNode 模板 -->
                        <HierarchicalDataTemplate DataType="{x:Type local:RootNode}" ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="Blue"/>
                        </HierarchicalDataTemplate>
                        
                        <!-- FileItem 模板 -->
                        <HierarchicalDataTemplate DataType="{x:Type local:FileItem}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding FileName}" Width="300" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Status}" Margin="10,0,0,0" Foreground="Gray"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </GroupBox>

            <!-- 分隔条 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <!-- 右侧：信息输出 -->
            <GroupBox Grid.Column="2" Header="信息输出" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 最终路径显示区域 -->
                    <Border Grid.Row="0" Background="#F0F8FF" BorderBrush="#4682B4" BorderThickness="1" Margin="5" Padding="10" CornerRadius="3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="最终路径:" FontWeight="Bold" Foreground="#4682B4" Margin="0,0,10,0"/>
                            <TextBox x:Name="TxtFinalPath" Text="无" Foreground="#333333" 
                                     BorderThickness="0" Background="Transparent" IsReadOnly="True"
                                     TextWrapping="Wrap" VerticalAlignment="Center"
                                     Cursor="Arrow"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 日志文本框 -->
                    <TextBox Grid.Row="1" x:Name="TxtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Background="White" FontFamily="Consolas" FontSize="12"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="4" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatusTestThread" Text="测试线程: 空闲" Margin="0,0,20,0"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="TxtStatusExtractThread" Text="解压线程: 空闲" Margin="0,0,20,0"/>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="解压进度:" Margin="0,0,5,0"/>
                    <ProgressBar x:Name="ProgressExtract" Width="200" Height="18" Minimum="0" Maximum="100" Value="0" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtExtractProgress" Text="0%" Margin="0,0,20,0" Width="35"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtStatusCurrentPassword" Text="测试中的密码: 无"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
