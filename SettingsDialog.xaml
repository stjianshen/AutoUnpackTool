<Window x:Class="AutoUnpackTool.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="软件设置" Width="650" SizeToContent="Height" MinHeight="500" MaxHeight="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 配置文件路径 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="配置文件路径:" FontWeight="Bold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TxtConfigPath" Width="420" Height="30" VerticalContentAlignment="Center" IsReadOnly="True" Background="LightGray" Margin="0,0,10,0"/>
                    <Button x:Name="BtnOpenConfigFolder" Content="打开文件夹" Width="100" Height="30" Click="BtnOpenConfigFolder_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- 7z.exe路径设置 -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="解压软件路径 (7z.exe):" FontWeight="Bold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TxtSevenZipPath" Width="420" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                    <Button x:Name="BtnBrowse7z" Content="浏览..." Width="100" Height="30" Click="BtnBrowse7z_Click"/>
                </StackPanel>
                <TextBlock Text="提示：请找到7-Zip安装目录下的 7z.exe 文件" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- 基础设置 - 可折叠 -->
            <Expander Grid.Row="2" Header="📁 基础设置" IsExpanded="True" Margin="0,0,0,10">
                <StackPanel Margin="10,10,0,0">
                    <!-- 解压后文件处理方式 -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="解压后原文件处理:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <RadioButton x:Name="RdoKeepOriginal" Content="保留原文件" GroupName="FileAction" IsChecked="True" Margin="0,0,0,5"/>
                        <RadioButton x:Name="RdoMoveToRecycleBin" Content="移动到回收站" GroupName="FileAction" Margin="0,0,0,5"/>
                        <RadioButton x:Name="RdoDeleteOriginal" Content="直接删除" GroupName="FileAction"/>
                    </StackPanel>

                    <!-- 解压模式 -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="解压模式:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <RadioButton x:Name="RdoManualExtract" Content="手动解压（测试密码后手动确认）" GroupName="ExtractMode" IsChecked="True" Margin="0,0,0,5"/>
                        <RadioButton x:Name="RdoAutoExtract" Content="自动解压（测试密码后自动解压）" GroupName="ExtractMode" Margin="0,0,0,5"/>
                    </StackPanel>

                    <!-- 线程数设置 -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="并发线程数:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="SliderThreads" Width="350" Minimum="1" Maximum="8" Value="2" 
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtThreadsCount" Text="2" Width="30" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- 高级设置 - 可折叠 -->
            <Expander Grid.Row="3" Header="⚙️ 高级设置" IsExpanded="False" Margin="0,0,0,10">
                <StackPanel Margin="10,10,0,0">
                    <!-- 显示CLI窗口 -->
                    <StackPanel Margin="0,0,0,15">
                        <CheckBox x:Name="ChkShowCliWindow" Content="显示 7z 命令行窗口（用于调试）" VerticalAlignment="Center"/>
                        <TextBlock Text="提示：开启后会显示7z.exe的控制台窗口，关闭则隐藏窗口" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- 智能路径处理 -->
                    <StackPanel Margin="0,0,0,15">
                        <CheckBox x:Name="ChkSmartPathProcessing" Content="启用智能路径处理（自动扁平化多层嵌套文件夹）" VerticalAlignment="Center"/>
                        <TextBlock Text="提示：解压后如果存在多层嵌套且内容单一，会自动将深层文件夹移动到顶层并清理空目录" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                        
                        <!-- 智能路径处理模式 -->
                        <StackPanel x:Name="PnlSmartPathMode" Margin="20,10,0,0" Visibility="Collapsed">
                            <TextBlock Text="处理模式:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <RadioButton x:Name="RdoSmartPathConcatenate" Content="拼接文件夹名字" GroupName="SmartPathMode" Margin="0,0,0,5"/>
                            <RadioButton x:Name="RdoSmartPathSmartSelect" Content="智能选择（优先选择长的、有日文的）" GroupName="SmartPathMode" IsChecked="True"/>
                            <TextBlock Text="• 拼接模式：将所有层级文件夹名用下划线连接" FontSize="10" Foreground="Gray" Margin="0,3,0,0"/>
                            <TextBlock Text="• 智能选择：根据文件夹名长度和是否包含日文自动选择最合适的名称" FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 解压输出模式 -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="解压输出模式:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <RadioButton x:Name="RdoOutputToSpecificDir" Content="输出到指定目录" GroupName="OutputMode" Margin="0,0,0,5" Checked="OutputMode_Checked"/>
                        <RadioButton x:Name="RdoOutputToArchiveDir" Content="输出到压缩文件所在目录" GroupName="OutputMode" Margin="0,0,0,5" Checked="OutputMode_Checked"/>
                        <RadioButton x:Name="RdoOutputToArchiveFolder" Content="输出到压缩文件同名文件夹" GroupName="OutputMode" Checked="OutputMode_Checked"/>
                                
                        <!-- 输出目录选择（仅在"输出到指定目录"模式下显示） -->
                        <StackPanel x:Name="PnlOutputDir" Margin="20,5,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtOutputDir" Width="420" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                                <Button x:Name="BtnBrowseOutputDir" Content="浏览..." Width="100" Height="30" Click="BtnBrowseOutputDir_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- 文件检测设置 - 可折叠 -->
            <Expander Grid.Row="4" Header="🔍 文件检测设置" IsExpanded="False" Margin="0,0,0,15">
                <StackPanel Margin="10,10,0,0">
                    <TextBlock Text="压缩文件扩展名检测:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="需要检测的扩展名（逗号分隔）:" FontSize="11" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtArchiveExtensions" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>
                    <TextBlock Text="需要排除的扩展名（逗号分隔，优先级高于包含列表）:" FontSize="11" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtExcludedExtensions" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,5"/>
                    <TextBlock Text="提示：符合扩展名的文件会用魔术数验证是否为压缩文件；排除列表中的文件直接跳过" FontSize="11" Foreground="Gray"/>
                </StackPanel>
            </Expander>

            <!-- 黑名单文件设置 - 可折叠 -->
            <Expander Grid.Row="5" Header="🚫 黑名单文件设置" IsExpanded="False" Margin="0,0,0,15">
                <StackPanel Margin="10,10,0,0">
                    <TextBlock Text="黑名单文件模式（逗号分隔，支持通配符 * 和 ?）:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtBlacklistFiles" Height="80" TextWrapping="Wrap" 
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,5"/>
                    <TextBlock Text="示例: *.tmp, C:\Temp\*, *temp*" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="⚠️ 警告：匹配的文件将被永久删除（不经过回收站，不可恢复）" 
                               FontSize="11" Foreground="Red" Margin="0,5,0,0"/>
                </StackPanel>
            </Expander>

            <!-- 分隔线 -->
            <Separator Grid.Row="6" Margin="0,10,0,10"/>

            <!-- 说明信息 -->
            <TextBlock Grid.Row="6" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,10">
                <Run Text="• 所有配置（包括密码本）都保存在一个JSON文件中"/>
                <LineBreak/>
                <Run Text="• 7z.exe 是 7-Zip 的命令行版本，需要从 7-Zip 官网下载"/>
                <LineBreak/>
                <Run Text="• 点击&quot;保存配置&quot;按钮手动保存所有设置"/>
            </TextBlock>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,50,0,0">
                <Button x:Name="BtnSave" Content="💾 保存配置" Width="120" Height="35" Click="BtnSave_Click" Margin="0,0,10,0" FontWeight="Bold"/>
                <Button x:Name="BtnCancel" Content="取消" Width="100" Height="35" Click="BtnCancel_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
