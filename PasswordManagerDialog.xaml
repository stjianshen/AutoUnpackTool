<Window x:Class="AutoUnpackTool.PasswordManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="密码本管理" Height="550" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 添加密码区域 -->
        <GroupBox Grid.Row="0" Header="添加密码" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="密码：" VerticalAlignment="Center" Width="60"/>
                    <TextBox x:Name="TxtNewPassword" Width="300" Height="30" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="ChkOneTime" Content="一次性密码（仅本次运行有效）" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <Button x:Name="BtnAddPassword" Content="添加密码" Width="120" Height="30" Click="BtnAddPassword_Click" HorizontalAlignment="Left"/>
            </StackPanel>
        </GroupBox>

        <!-- 密码列表 -->
        <GroupBox Grid.Row="1" Header="密码列表（按使用频率和最近使用时间排序）" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="DgPasswords" Grid.Column="0" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="序号" Width="50" Binding="{Binding Index}"/>
                        <DataGridTextColumn Header="密码" Width="*" Binding="{Binding Password}"/>
                        <DataGridTextColumn Header="使用次数" Width="80" Binding="{Binding UsageCount}"/>
                        <DataGridTextColumn Header="最后使用" Width="120" Binding="{Binding LastUsedTime, StringFormat='yyyy-MM-dd HH:mm'}"/>
                        <DataGridTextColumn Header="类型" Width="70" Binding="{Binding Type}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top">
                    <Button x:Name="BtnMoveUp" Content="↑ 上移" Width="100" Height="30" Margin="0,0,0,5" Click="BtnMoveUp_Click"/>
                    <Button x:Name="BtnMoveDown" Content="↓ 下移" Width="100" Height="30" Margin="0,0,0,5" Click="BtnMoveDown_Click"/>
                    <Button x:Name="BtnDeletePassword" Content="✕ 删除" Width="100" Height="30" Click="BtnDeletePassword_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 密码本文件路径 -->
        <GroupBox Grid.Row="2" Header="密码本文件" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox x:Name="TxtPasswordFilePath" Width="450" Height="30" VerticalContentAlignment="Center" IsReadOnly="True" Margin="0,0,10,0"/>
                    <Button x:Name="BtnBrowseFile" Content="浏览..." Width="100" Height="30" Click="BtnBrowseFile_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnImportPassword" Content="导入到配置" Width="120" Height="30" Click="BtnImportPassword_Click" Margin="0,0,10,0" Background="LightGreen"/>
                    <Button x:Name="BtnExportPassword" Content="导出密码本" Width="120" Height="30" Click="BtnExportPassword_Click" Background="LightBlue"/>
                </StackPanel>
                <TextBlock Text='提示：选择文件后自动加载到当前列表（一次性使用），点击"导入到配置"将密码永久保存到配置文件' FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- 说明 -->
        <TextBlock Grid.Row="3" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,10">
            <Run Text="• 一次性密码：仅在本次软件运行期间有效，添加后排在第一位"/>
            <LineBreak/>
            <Run Text="• 永久密码：导入到配置后会自动保存，下次启动自动加载"/>
            <LineBreak/>
            <Run Text="• 使用次数：密码被成功匹配的次数，次数越多排名越靠前"/>
        </TextBlock>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSave" Content="保存" Width="100" Height="30" Click="BtnSave_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnCancel" Content="取消" Width="100" Height="30" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
