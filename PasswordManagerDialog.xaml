<Window x:Class="AutoUnpackTool.PasswordManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="密码本管理" Height="750" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 搜索区域 -->
        <GroupBox Grid.Row="0" Header="搜索密码" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSearch" Grid.Column="0" Height="30" VerticalContentAlignment="Center" TextChanged="TxtSearch_TextChanged"/>
                <Button x:Name="BtnClearSearch" Grid.Column="1" Content="清除" Width="80" Height="30" Click="BtnClearSearch_Click" Margin="10,0,0,0"/>
            </Grid>
        </GroupBox>

        <!-- 添加密码区域 -->
        <GroupBox Grid.Row="1" Header="添加密码" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="密码：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="TxtNewPassword" Grid.Row="0" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                <CheckBox x:Name="ChkOneTime" Grid.Row="0" Grid.Column="2" Content="一次性密码（仅本次运行有效）" VerticalAlignment="Center"/>
                
                <Button x:Name="BtnAddPassword" Grid.Row="1" Grid.Column="0" Content="添加密码" Width="120" Height="30" Click="BtnAddPassword_Click" HorizontalAlignment="Left" Margin="0,5,0,0"/>
            </Grid>
        </GroupBox>

        <!-- 密码列表 -->
        <GroupBox Grid.Row="2" Header="密码列表（按使用频率和最近使用时间排序）" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="DgPasswords" Grid.Column="0" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Extended"
                          Background="White">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制密码" Click="MenuItem_CopyPassword_Click"/>
                            <Separator/>
                            <MenuItem Header="上移" Click="BtnMoveUp_Click"/>
                            <MenuItem Header="下移" Click="BtnMoveDown_Click"/>
                            <Separator/>
                            <MenuItem Header="删除选中" Click="BtnDeletePassword_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="序号" Width="60" Binding="{Binding Index}"/>
                        <DataGridTextColumn Header="密码" Width="2*" Binding="{Binding Password}"/>
                        <DataGridTextColumn Header="使用次数" Width="80" Binding="{Binding UsageCount}"/>
                        <DataGridTextColumn Header="最后使用" Width="140" Binding="{Binding LastUsedTime, StringFormat='yyyy-MM-dd HH:mm'}"/>
                        <DataGridTextColumn Header="类型" Width="80" Binding="{Binding Type}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top">
                    <Button x:Name="BtnMoveUp" Content="↑ 上移" Width="100" Height="30" Margin="0,0,0,5" Click="BtnMoveUp_Click"/>
                    <Button x:Name="BtnMoveDown" Content="↓ 下移" Width="100" Height="30" Margin="0,0,0,5" Click="BtnMoveDown_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 批量操作栏 -->
        <GroupBox Grid.Row="3" Header="批量操作" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="10">
                <Button x:Name="BtnSelectAll" Content="Ctrl+A 全选" Width="120" Height="30" Click="BtnSelectAll_Click" Margin="0,0,10,0"/>
                <Button x:Name="BtnInvertSelection" Content="反选" Width="80" Height="30" Click="BtnInvertSelection_Click" Margin="0,0,10,0"/>
                <Button x:Name="BtnCopyPasswords" Content="📋 复制密码" Width="120" Height="30" Click="BtnCopyPasswords_Click" Background="LightYellow" Margin="0,0,10,0"/>
                <Button x:Name="BtnBatchDelete" Content="批量删除选中" Width="120" Height="30" Click="BtnBatchDelete_Click" Background="#FFCC99"/>
                <TextBlock x:Name="TxtSelectedCount" Text="已选择: 0 项" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="Gray"/>
            </StackPanel>
        </GroupBox>

        <!-- 密码本文件路径 -->
        <GroupBox Grid.Row="4" Header="密码本文件" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtPasswordFilePath" Grid.Column="0" Height="30" VerticalContentAlignment="Center" IsReadOnly="True" Margin="0,0,10,0"/>
                    <Button x:Name="BtnBrowseFile" Grid.Column="1" Content="浏览..." Width="100" Height="30" Click="BtnBrowseFile_Click"/>
                </Grid>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnImportPassword" Content="导入到配置" Width="120" Height="30" Click="BtnImportPassword_Click" Margin="0,0,10,0" Background="LightGreen"/>
                    <Button x:Name="BtnExportPassword" Content="导出密码本" Width="120" Height="30" Click="BtnExportPassword_Click" Background="LightBlue"/>
                </StackPanel>
                <TextBlock Text='提示：选择文件后自动加载到当前列表（一次性使用），点击"导入到配置"将密码永久保存到配置文件' FontSize="11" Foreground="Gray" Margin="0,5,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <!-- 说明 -->
        <TextBlock Grid.Row="5" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,10">
            <Run Text="• 一次性密码：仅在本次软件运行期间有效，添加后排在第一位"/>
            <LineBreak/>
            <Run Text="• 永久密码：导入到配置后会自动保存，下次启动自动加载"/>
            <LineBreak/>
            <Run Text="• 使用次数：密码被成功匹配的次数，次数越多排名越靠前"/>
        </TextBlock>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSave" Content="保存" Width="100" Height="30" Click="BtnSave_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnCancel" Content="取消" Width="100" Height="30" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
